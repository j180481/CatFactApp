<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatFactApp.Views.SavedFactsPage"
             Title="SavedFactsPage"
             BackgroundColor="{AppThemeBinding Light=White, Dark=Black}">
    <Grid RowDefinitions="Auto,*,Auto">
        <Label 
            Grid.Row="0"
            Text="Your Saved Facts"
            x:Name="SavedFactsHeader"
            FontSize="23"
            FontAttributes="Bold"
            TextDecorations="Underline"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <CollectionView Grid.Row="1" x:Name="FactsCollectionView" Margin="0,10,0,0" SelectionMode="Multiple">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.LeftItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="LightPink"
                                           Invoked="OnDeleteSwipeInvoked"/>
                            </SwipeItems>
                        </SwipeView.LeftItems>
                        <StackLayout Padding="5">
                            <Label Text="{Binding fact}" FontFamily="Serif" FontSize="{Binding FontSize}"/>
                            <Label Text="{Binding time}" FontFamily="Serif" />
                        </StackLayout>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <HorizontalStackLayout Grid.Row="2">
            <Button
                x:Name="ButtonAscending"
                Text="Order by Ascending"
                TextColor="{AppThemeBinding Light=White, Dark=White}"
                BackgroundColor="{AppThemeBinding Light=SaddleBrown, Dark=Blue}"
                Clicked="ButtonAscending_Clicked"/>
            <Button
                x:Name="ButtonDescending"
                Text="Order by Descending"
                TextColor="{AppThemeBinding Light=White, Dark=White}"
                BackgroundColor="{AppThemeBinding Light=SaddleBrown, Dark=Blue}"
                Clicked="ButtonDescending_Clicked"/>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>